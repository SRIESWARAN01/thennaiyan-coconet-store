# Copy to .env.local and fill in.
# Get these EXACT values from Supabase Dashboard -> Project Settings -> API.
# The URL looks like https://abcdefghijklmnop.supabase.co (lowercase project ref).
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-OR-PUBLISHABLE-KEY

# Server-only (never expose to client)
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY

# Demo/offline auth. Leave "false" (or unset) for a real, live site so that
# every login and order uses the real Supabase database.
# Set to "true" only to demo the UI locally without a Supabase connection
# (enables admin@gmail.com/adminpassword and OTP code 123456).
NEXT_PUBLIC_ENABLE_MOCK_AUTH=false

# Razorpay (for checkout — wire up in Phase 4)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
NEXT_PUBLIC_RAZORPAY_KEY_ID=
